{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nene-records.dev/schemas/blocks.schema.json",
  "title": "Post Blocks Document",
  "description": "Canonical shape of a `blocks` field value (epic #486): an ordered list of curated, typed blocks. Server validation lives in src/BlocksField/BlocksDocumentValidator.php (the trust boundary); this schema is the contract source for the frontend (Ajv) and codegen. Curated typed blocks, NOT a free-form page builder.",
  "type": "array",
  "maxItems": 200,
  "items": { "$ref": "#/$defs/block" },
  "$defs": {
    "block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "data"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Client-generated stable key (React key / future anchor). Opaque.",
          "minLength": 1,
          "maxLength": 64
        },
        "type": { "enum": ["text", "callout", "hero", "gallery", "chart", "group"] },
        "data": { "type": "object" }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "text" } } },
          "then": { "properties": { "data": { "$ref": "#/$defs/textData" } } }
        },
        {
          "if": { "properties": { "type": { "const": "callout" } } },
          "then": { "properties": { "data": { "$ref": "#/$defs/calloutData" } } }
        },
        {
          "if": { "properties": { "type": { "const": "hero" } } },
          "then": { "properties": { "data": { "$ref": "#/$defs/heroData" } } }
        },
        {
          "if": { "properties": { "type": { "const": "gallery" } } },
          "then": { "properties": { "data": { "$ref": "#/$defs/galleryData" } } }
        },
        {
          "if": { "properties": { "type": { "const": "chart" } } },
          "then": { "properties": { "data": { "$ref": "#/$defs/chartData" } } }
        },
        {
          "if": { "properties": { "type": { "const": "group" } } },
          "then": { "properties": { "data": { "$ref": "#/$defs/groupData" } } }
        }
      ]
    },
    "groupData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tone", "children"],
      "description": "Layout container holding child blocks (#491 WS2). The server validator further restricts children to leaf blocks (no container nesting; depth 2).",
      "properties": {
        "tone": { "enum": ["plain", "muted", "card"] },
        "children": { "type": "array", "maxItems": 30, "items": { "$ref": "#/$defs/block" } }
      }
    },
    "textData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["markdown"],
      "properties": {
        "markdown": { "type": "string", "minLength": 1, "maxLength": 50000 }
      }
    },
    "calloutData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "body"],
      "properties": {
        "kind": { "enum": ["info", "warn", "ok", "danger"] },
        "title": { "type": "string", "maxLength": 200 },
        "body": { "type": "string", "minLength": 1, "maxLength": 50000 }
      }
    },
    "heroData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["variant", "heading"],
      "description": "Reuses the existing .hero__* presentation; variant maps to data-hero. Image art arrives in a later slice (S3 media picker).",
      "properties": {
        "variant": { "enum": ["standard", "minimal", "fullbleed"] },
        "heading": { "type": "string", "minLength": 1, "maxLength": 300 },
        "kicker": { "type": "string", "maxLength": 200 },
        "lead": { "type": "string", "maxLength": 2000 },
        "ctaLabel": { "type": "string", "maxLength": 120 },
        "ctaUrl": { "type": "string", "maxLength": 2000 },
        "ghostLabel": { "type": "string", "maxLength": 120 },
        "ghostUrl": { "type": "string", "maxLength": 2000 },
        "media": { "$ref": "#/$defs/mediaRef" }
      }
    },
    "mediaRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mediaId", "url"],
      "description": "A picker-selected library image. url is a same-origin /media/... path (local driver) or an https:// url (object-storage/CDN driver); the consumer renders the stored url directly (the media metadata API is admin-only), like the image field type. Protocol-relative // and insecure schemes are rejected server-side.",
      "properties": {
        "mediaId": { "type": "string", "minLength": 1, "maxLength": 64 },
        "url": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "alt": { "type": "string", "maxLength": 300 }
      }
    },
    "galleryData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layout", "items"],
      "description": "An ordered list of library images shown as a no-JS scroll-snap carousel or a grid. Every item requires alt (C4).",
      "properties": {
        "layout": { "enum": ["carousel", "grid"] },
        "items": {
          "type": "array",
          "minItems": 1,
          "maxItems": 50,
          "items": { "$ref": "#/$defs/galleryItem" }
        }
      }
    },
    "galleryItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mediaId", "url", "alt"],
      "properties": {
        "mediaId": { "type": "string", "minLength": 1, "maxLength": 64 },
        "url": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "alt": { "type": "string", "minLength": 1, "maxLength": 300 },
        "caption": { "type": "string", "maxLength": 300 }
      }
    },
    "chartData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chartType", "series", "summary"],
      "description": "First-party bar/line chart. summary is the required sr-only projection (C4); the consumer also renders a data table.",
      "properties": {
        "chartType": { "enum": ["bar", "line"] },
        "title": { "type": "string", "maxLength": 300 },
        "series": {
          "type": "array",
          "minItems": 2,
          "maxItems": 60,
          "items": { "$ref": "#/$defs/seriesPoint" }
        },
        "summary": { "type": "string", "minLength": 1, "maxLength": 2000 }
      }
    },
    "seriesPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "value"],
      "properties": {
        "label": { "type": "string", "minLength": 1, "maxLength": 120 },
        "value": { "type": "number" }
      }
    }
  }
}
