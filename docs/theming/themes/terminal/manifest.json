{
  "$schema": "../public-theme.schema.json",
  "id": "terminal",
  "name": "Terminal",
  "version": "1.0.0",
  "author": "NeNe Records",
  "description": "Terminal / CRT — phosphor green on near-black, an all-mono typeface (JetBrains Mono), scanline nuance and a technical, niche voice. components.css is the star: all-mono type, scanline hero, bordered list rows, grayscale media and caps labels with a blinking caret accent. Dark-led; both modes AA.",
  "supportsModes": [
    "light",
    "dark"
  ],
  "fonts": [
    {
      "family": "JetBrains Mono",
      "role": "display",
      "source": "fontsource",
      "weights": [
        400,
        500,
        700
      ]
    },
    {
      "family": "JetBrains Mono",
      "role": "body",
      "source": "fontsource",
      "weights": [
        400,
        500
      ]
    },
    {
      "family": "JetBrains Mono",
      "role": "mono",
      "source": "fontsource",
      "weights": [
        400,
        500
      ]
    }
  ],
  "tokens": {
    "light": {
      "color-surface": "oklch(96% 0.006 150)",
      "color-surface-raised": "oklch(98% 0.006 150)",
      "color-surface-overlay": "oklch(92.5% 0.008 150)",
      "color-surface-sunken": "oklch(94.2% 0.006 150)",
      "color-text-primary": "oklch(24% 0.02 150)",
      "color-text-muted": "oklch(48% 0.018 150)",
      "color-text-inverse": "oklch(99% 0.006 150)",
      "color-border": "oklch(84% 0.01 150)",
      "color-border-strong": "oklch(73% 0.014 150)",
      "color-focus-ring": "oklch(52% 0.15 150)",
      "color-accent": "oklch(52% 0.15 150)",
      "color-accent-hover": "oklch(46% 0.15 150)",
      "color-accent-weak": "color-mix(in oklch, var(--color-accent) 12%, var(--color-surface-raised))",
      "color-on-accent": "oklch(98% 0.02 150)",
      "color-brand-violet": "oklch(58% 0.13 75)",
      "color-danger": "oklch(52% 0.2 25)",
      "color-danger-hover": "oklch(46% 0.2 25)",
      "color-ok": "oklch(55% 0.13 150)",
      "color-warn": "oklch(70% 0.15 75)",
      "color-info": "oklch(55% 0.13 250)",
      "shadow-sm": "0 1px 2px oklch(40% 0.04 150 / 0.08)",
      "shadow-md": "0 6px 20px oklch(40% 0.04 150 / 0.1), 0 2px 6px oklch(40% 0.04 150 / 0.08)",
      "shadow-lg": "0 24px 54px oklch(38% 0.05 150 / 0.16)",
      "shadow-focus": "0 0 0 3px color-mix(in oklch, var(--color-focus-ring) 30%, transparent)",
      "color-scheme": "light"
    },
    "dark": {
      "color-surface": "oklch(14% 0.01 150)",
      "color-surface-raised": "oklch(18% 0.01 150)",
      "color-surface-overlay": "oklch(23% 0.013 150)",
      "color-surface-sunken": "oklch(10.5% 0.01 150)",
      "color-text-primary": "oklch(88% 0.05 150)",
      "color-text-muted": "oklch(63% 0.045 150)",
      "color-text-inverse": "oklch(20% 0.01 150)",
      "color-border": "oklch(29% 0.014 150)",
      "color-border-strong": "oklch(42% 0.018 150)",
      "color-focus-ring": "oklch(82% 0.2 145)",
      "color-accent": "oklch(82% 0.2 145)",
      "color-accent-hover": "oklch(89% 0.2 145)",
      "color-accent-weak": "color-mix(in oklch, var(--color-accent) 16%, var(--color-surface-raised))",
      "color-on-accent": "oklch(14% 0.04 145)",
      "color-brand-violet": "oklch(80% 0.15 75)",
      "color-danger": "oklch(66% 0.18 25)",
      "color-danger-hover": "oklch(72% 0.18 25)",
      "color-ok": "oklch(72% 0.14 150)",
      "color-warn": "oklch(80% 0.14 80)",
      "color-info": "oklch(74% 0.12 250)",
      "shadow-sm": "0 1px 2px oklch(0% 0 0 / 0.4)",
      "shadow-md": "0 10px 28px oklch(0% 0 0 / 0.5), 0 2px 6px oklch(0% 0 0 / 0.4)",
      "shadow-lg": "0 28px 60px oklch(0% 0 0 / 0.62)",
      "shadow-focus": "0 0 0 3px color-mix(in oklch, var(--color-focus-ring) 30%, transparent)",
      "color-scheme": "dark"
    }
  },
  "flags": {
    "feedLayout": "list",
    "cardStyle": "bordered",
    "media": "grayscale",
    "hero": "minimal",
    "sectionRule": "hairline",
    "eyebrow": "caps"
  },
  "knobs": {
    "accent": {
      "light": "oklch(52% 0.15 150)",
      "dark": "oklch(82% 0.2 145)"
    },
    "surface": {
      "light": "oklch(96% 0.006 150)",
      "dark": "oklch(14% 0.01 150)"
    },
    "fontDisplay": "JetBrains Mono",
    "fontBody": "JetBrains Mono",
    "fontMono": "JetBrains Mono",
    "baseFontSize": "1rem",
    "typeScale": 1.2,
    "density": "compact",
    "radius": "sharp"
  }
}
