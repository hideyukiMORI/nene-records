{
  "$schema": "../public-theme.schema.json",
  "id": "newsprint",
  "name": "Newsprint",
  "version": "1.0.0",
  "author": "NeNe Records",
  "description": "Ink-on-paper journalism — a warm newsprint cream-grey paper, near-black ink, a single newsprint-red accent, bold tight Source Serif headlines and a dense, ruled, multi-column page. The inverse of Reading (intimate, narrow): Newsprint is wide, dense and indexical. components.css is the star: double-rule mastheads, hairline rules everywhere, mono datelines, a vertical column rule, a front-page lead, a prose drop cap and grayscale photos that bloom on hover. Light + dark, both AA.",
  "supportsModes": ["light", "dark"],
  "fonts": [
    { "family": "Source Serif 4", "role": "display", "source": "fontsource", "weights": [400, 600, 700] },
    { "family": "Inter", "role": "body", "source": "fontsource", "weights": [400, 500, 600] },
    { "family": "Inter", "role": "chrome", "source": "fontsource", "weights": [500, 600] },
    { "family": "JetBrains Mono", "role": "mono", "source": "fontsource", "weights": [400, 500] }
  ],
  "tokens": {
    "light": {
      "color-surface": "oklch(95% 0.008 85)",
      "color-surface-raised": "oklch(97% 0.006 85)",
      "color-surface-overlay": "oklch(91% 0.01 85)",
      "color-surface-sunken": "oklch(92.5% 0.009 85)",
      "color-text-primary": "oklch(22% 0.006 60)",
      "color-text-muted": "oklch(44% 0.008 60)",
      "color-text-inverse": "oklch(97% 0.006 85)",
      "color-border": "oklch(80% 0.008 75)",
      "color-border-strong": "oklch(60% 0.01 70)",
      "color-focus-ring": "oklch(50% 0.17 25)",
      "color-accent": "oklch(50% 0.18 25)",
      "color-accent-hover": "oklch(44% 0.18 25)",
      "color-accent-weak": "color-mix(in oklch, var(--color-accent) 12%, var(--color-surface-raised))",
      "color-on-accent": "oklch(98% 0.005 85)",
      "color-brand-violet": "oklch(44% 0.13 280)",
      "color-danger": "oklch(50% 0.2 25)",
      "color-danger-hover": "oklch(44% 0.2 25)",
      "color-ok": "oklch(50% 0.12 150)",
      "color-warn": "oklch(64% 0.14 70)",
      "color-info": "oklch(44% 0.1 250)",
      "shadow-sm": "0 1px 0 oklch(40% 0.01 70 / 0.08)",
      "shadow-md": "0 1px 0 oklch(40% 0.01 70 / 0.1)",
      "shadow-lg": "0 2px 0 oklch(40% 0.01 70 / 0.12)",
      "shadow-focus": "0 0 0 3px color-mix(in oklch, var(--color-focus-ring) 28%, transparent)",
      "color-scheme": "light"
    },
    "dark": {
      "color-surface": "oklch(18% 0.006 60)",
      "color-surface-raised": "oklch(22% 0.007 60)",
      "color-surface-overlay": "oklch(27% 0.008 60)",
      "color-surface-sunken": "oklch(14% 0.005 60)",
      "color-text-primary": "oklch(93% 0.006 80)",
      "color-text-muted": "oklch(66% 0.008 70)",
      "color-text-inverse": "oklch(18% 0.006 60)",
      "color-border": "oklch(34% 0.008 60)",
      "color-border-strong": "oklch(48% 0.01 60)",
      "color-focus-ring": "oklch(64% 0.19 25)",
      "color-accent": "oklch(52% 0.2 25)",
      "color-accent-hover": "oklch(58% 0.19 25)",
      "color-accent-weak": "color-mix(in oklch, var(--color-accent) 22%, var(--color-surface-raised))",
      "color-on-accent": "oklch(98% 0.005 85)",
      "color-brand-violet": "oklch(70% 0.13 280)",
      "color-danger": "oklch(64% 0.19 25)",
      "color-danger-hover": "oklch(70% 0.18 25)",
      "color-ok": "oklch(72% 0.13 150)",
      "color-warn": "oklch(78% 0.13 75)",
      "color-info": "oklch(72% 0.1 250)",
      "shadow-sm": "0 1px 0 oklch(0% 0 0 / 0.4)",
      "shadow-md": "0 1px 0 oklch(0% 0 0 / 0.45)",
      "shadow-lg": "0 2px 0 oklch(0% 0 0 / 0.5)",
      "shadow-focus": "0 0 0 3px color-mix(in oklch, var(--color-focus-ring) 32%, transparent)",
      "color-scheme": "dark"
    }
  },
  "flags": {
    "feedLayout": "magazine",
    "cardStyle": "bordered",
    "media": "grayscale",
    "hero": "minimal",
    "sectionRule": "hairline",
    "eyebrow": "caps"
  },
  "knobs": {
    "accent": { "light": "oklch(50% 0.18 25)", "dark": "oklch(52% 0.2 25)" },
    "surface": { "light": "oklch(95% 0.008 85)", "dark": "oklch(18% 0.006 60)" },
    "textPrimary": { "light": "oklch(22% 0.006 60)", "dark": "oklch(93% 0.006 80)" },
    "fontDisplay": "Source Serif 4",
    "fontBody": "Inter",
    "fontMono": "JetBrains Mono",
    "baseFontSize": "1rem",
    "typeScale": 1.25,
    "density": "compact",
    "radius": "sharp"
  }
}
