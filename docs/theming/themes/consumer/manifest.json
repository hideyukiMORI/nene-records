{
  "$schema": "../public-theme.schema.json",
  "id": "consumer",
  "name": "Terracotta",
  "version": "2.0.0",
  "author": "NeNe Records",
  "description": "Warm photo-magazine — the standard axis. Terracotta/clay warmth on a warm off-white paper, photography treated large and vivid, soft corners and a friendly humanist voice (Bricolage Grotesque display). Redesign of the bare shipped consumer theme: components.css gives it a face — issue-cover hero, big photo cards that float and round, a cover-photo lead, warm terracotta kickers and soft pills. Light + dark, both AA (dark text rides on the vivid clay accent).",
  "supportsModes": ["light", "dark"],
  "fonts": [
    { "family": "Bricolage Grotesque", "role": "display", "source": "fontsource", "weights": [500, 600, 700, 800] },
    { "family": "Bricolage Grotesque", "role": "chrome", "source": "fontsource", "weights": [500, 600] },
    { "family": "Inter", "role": "body", "source": "fontsource", "weights": [400, 500, 600] },
    { "family": "JetBrains Mono", "role": "mono", "source": "fontsource", "weights": [400, 500] }
  ],
  "tokens": {
    "light": {
      "color-surface": "oklch(97.5% 0.012 75)",
      "color-surface-raised": "oklch(99.5% 0.008 75)",
      "color-surface-overlay": "oklch(94% 0.02 75)",
      "color-surface-sunken": "oklch(95.5% 0.016 70)",
      "color-text-primary": "oklch(24% 0.03 55)",
      "color-text-muted": "oklch(48% 0.03 55)",
      "color-text-inverse": "oklch(99% 0.005 75)",
      "color-border": "oklch(86% 0.02 75)",
      "color-border-strong": "oklch(78% 0.025 70)",
      "color-focus-ring": "oklch(60% 0.13 45)",
      "color-accent": "oklch(58% 0.14 45)",
      "color-accent-hover": "oklch(52% 0.14 45)",
      "color-accent-weak": "color-mix(in oklch, var(--color-accent) 12%, var(--color-surface-raised))",
      "color-on-accent": "oklch(22% 0.05 45)",
      "color-brand-violet": "oklch(56% 0.24 300)",
      "color-danger": "oklch(52% 0.2 25)",
      "color-danger-hover": "oklch(46% 0.2 25)",
      "color-ok": "oklch(55% 0.13 150)",
      "color-warn": "oklch(70% 0.15 75)",
      "color-info": "oklch(55% 0.13 250)",
      "shadow-sm": "0 1px 2px oklch(40% 0.04 60 / 0.08)",
      "shadow-md": "0 8px 24px oklch(40% 0.04 60 / 0.12), 0 2px 6px oklch(40% 0.04 60 / 0.08)",
      "shadow-lg": "0 26px 56px oklch(38% 0.05 55 / 0.18)",
      "shadow-focus": "0 0 0 3px color-mix(in oklch, var(--color-focus-ring) 30%, transparent)",
      "color-scheme": "light"
    },
    "dark": {
      "color-surface": "oklch(18% 0.012 55)",
      "color-surface-raised": "oklch(22% 0.014 55)",
      "color-surface-overlay": "oklch(27% 0.016 50)",
      "color-surface-sunken": "oklch(15% 0.011 55)",
      "color-text-primary": "oklch(94% 0.012 75)",
      "color-text-muted": "oklch(68% 0.022 60)",
      "color-text-inverse": "oklch(20% 0.02 50)",
      "color-border": "oklch(32% 0.016 55)",
      "color-border-strong": "oklch(42% 0.02 55)",
      "color-focus-ring": "oklch(74% 0.13 45)",
      "color-accent": "oklch(70% 0.15 45)",
      "color-accent-hover": "oklch(77% 0.15 45)",
      "color-accent-weak": "color-mix(in oklch, var(--color-accent) 16%, var(--color-surface-raised))",
      "color-on-accent": "oklch(20% 0.04 45)",
      "color-brand-violet": "oklch(72% 0.18 300)",
      "color-danger": "oklch(66% 0.18 25)",
      "color-danger-hover": "oklch(72% 0.18 25)",
      "color-ok": "oklch(72% 0.14 150)",
      "color-warn": "oklch(80% 0.14 80)",
      "color-info": "oklch(74% 0.12 250)",
      "shadow-sm": "0 1px 2px oklch(0% 0 0 / 0.4)",
      "shadow-md": "0 10px 28px oklch(0% 0 0 / 0.5), 0 2px 6px oklch(0% 0 0 / 0.4)",
      "shadow-lg": "0 28px 60px oklch(0% 0 0 / 0.62)",
      "shadow-focus": "0 0 0 3px color-mix(in oklch, var(--color-focus-ring) 32%, transparent)",
      "color-scheme": "dark"
    }
  },
  "flags": {
    "feedLayout": "magazine",
    "cardStyle": "shadowed",
    "media": "plain",
    "hero": "standard",
    "sectionRule": "hairline",
    "eyebrow": "plain"
  },
  "knobs": {
    "accent": { "light": "oklch(58% 0.14 45)", "dark": "oklch(70% 0.15 45)" },
    "surface": { "light": "oklch(97.5% 0.012 75)", "dark": "oklch(18% 0.012 55)" },
    "textPrimary": { "light": "oklch(24% 0.03 55)", "dark": "oklch(94% 0.012 75)" },
    "fontDisplay": "Bricolage Grotesque",
    "fontBody": "Inter",
    "fontMono": "JetBrains Mono",
    "baseFontSize": "1.0625rem",
    "typeScale": 1.18,
    "density": "comfortable",
    "radius": "soft"
  }
}
