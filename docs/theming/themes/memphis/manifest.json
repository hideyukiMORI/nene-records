{
  "$schema": "../public-theme.schema.json",
  "id": "memphis",
  "name": "Memphis",
  "version": "1.0.0",
  "author": "NeNe Records",
  "description": "Memphis / 80s pop graphic — high-chroma primaries (red, blue, yellow) plus black, bold grotesque type, geometric confetti and black outlines. Loud and graphic. components.css is the star: heavy outlined cards, hard offset shadows, confetti accents, framed primary-colour media and barred eyebrows. Light + dark, both AA.",
  "supportsModes": [
    "light",
    "dark"
  ],
  "fonts": [
    {
      "family": "Space Grotesk",
      "role": "display",
      "source": "fontsource",
      "weights": [
        500,
        700
      ]
    },
    {
      "family": "Inter",
      "role": "body",
      "source": "fontsource",
      "weights": [
        400,
        500,
        600
      ]
    },
    {
      "family": "JetBrains Mono",
      "role": "mono",
      "source": "fontsource",
      "weights": [
        400,
        500
      ]
    }
  ],
  "tokens": {
    "light": {
      "color-surface": "oklch(99% 0 0)",
      "color-surface-raised": "oklch(99.5% 0 0)",
      "color-surface-overlay": "oklch(95.5% 0 0)",
      "color-surface-sunken": "oklch(97.2% 0 0)",
      "color-text-primary": "oklch(18% 0 0)",
      "color-text-muted": "oklch(42% 0 0)",
      "color-text-inverse": "oklch(99% 0 0)",
      "color-border": "oklch(87% 0.004 0)",
      "color-border-strong": "oklch(76% 0.008 0)",
      "color-focus-ring": "oklch(58% 0.21 25)",
      "color-accent": "oklch(58% 0.21 25)",
      "color-accent-hover": "oklch(52% 0.21 25)",
      "color-accent-weak": "color-mix(in oklch, var(--color-accent) 12%, var(--color-surface-raised))",
      "color-on-accent": "oklch(16% 0 0)",
      "color-brand-violet": "oklch(60% 0.18 250)",
      "color-danger": "oklch(52% 0.2 25)",
      "color-danger-hover": "oklch(46% 0.2 25)",
      "color-ok": "oklch(55% 0.13 150)",
      "color-warn": "oklch(70% 0.15 75)",
      "color-info": "oklch(55% 0.13 250)",
      "shadow-sm": "0 1px 2px oklch(40% 0.04 0 / 0.08)",
      "shadow-md": "0 6px 20px oklch(40% 0.04 0 / 0.1), 0 2px 6px oklch(40% 0.04 0 / 0.08)",
      "shadow-lg": "0 24px 54px oklch(38% 0.05 0 / 0.16)",
      "shadow-focus": "0 0 0 3px color-mix(in oklch, var(--color-focus-ring) 30%, transparent)",
      "color-scheme": "light"
    },
    "dark": {
      "color-surface": "oklch(17% 0 0)",
      "color-surface-raised": "oklch(21% 0 0)",
      "color-surface-overlay": "oklch(26% 0 0)",
      "color-surface-sunken": "oklch(13.5% 0 0)",
      "color-text-primary": "oklch(96% 0 0)",
      "color-text-muted": "oklch(71% 0 0)",
      "color-text-inverse": "oklch(20% 0 0)",
      "color-border": "oklch(32% 0.004 0)",
      "color-border-strong": "oklch(45% 0.008 0)",
      "color-focus-ring": "oklch(66% 0.21 25)",
      "color-accent": "oklch(64% 0.21 25)",
      "color-accent-hover": "oklch(71% 0.21 25)",
      "color-accent-weak": "color-mix(in oklch, var(--color-accent) 16%, var(--color-surface-raised))",
      "color-on-accent": "oklch(15% 0 0)",
      "color-brand-violet": "oklch(70% 0.16 250)",
      "color-danger": "oklch(66% 0.18 25)",
      "color-danger-hover": "oklch(72% 0.18 25)",
      "color-ok": "oklch(72% 0.14 150)",
      "color-warn": "oklch(80% 0.14 80)",
      "color-info": "oklch(74% 0.12 250)",
      "shadow-sm": "0 1px 2px oklch(0% 0 0 / 0.4)",
      "shadow-md": "0 10px 28px oklch(0% 0 0 / 0.5), 0 2px 6px oklch(0% 0 0 / 0.4)",
      "shadow-lg": "0 28px 60px oklch(0% 0 0 / 0.62)",
      "shadow-focus": "0 0 0 3px color-mix(in oklch, var(--color-focus-ring) 30%, transparent)",
      "color-scheme": "dark"
    }
  },
  "flags": {
    "feedLayout": "grid",
    "cardStyle": "framed",
    "media": "plain",
    "hero": "standard",
    "sectionRule": "heavy",
    "eyebrow": "barred"
  },
  "knobs": {
    "accent": {
      "light": "oklch(58% 0.21 25)",
      "dark": "oklch(64% 0.21 25)"
    },
    "surface": {
      "light": "oklch(99% 0 0)",
      "dark": "oklch(17% 0 0)"
    },
    "fontDisplay": "Space Grotesk",
    "fontBody": "Inter",
    "fontMono": "JetBrains Mono",
    "baseFontSize": "1.0625rem",
    "typeScale": 1.2,
    "density": "comfortable",
    "radius": "round"
  }
}
