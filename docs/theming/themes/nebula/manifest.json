{
  "$schema": "../public-theme.schema.json",
  "id": "nebula",
  "name": "Nebula",
  "version": "1.0.0",
  "author": "NeNe Records",
  "description": "Gradient glassmorphism — modern SaaS. Soft violet-to-blue-to-pink gradients, frosted glass (translucent + backdrop-filter) and a clean geometric sans. Future-leaning and polished. components.css is the star: gradient hero and headings, frosted glass cards/header, glowing violet accents and soft rounded forms. Light + dark, both AA.",
  "supportsModes": [
    "light",
    "dark"
  ],
  "fonts": [
    {
      "family": "Space Grotesk",
      "role": "display",
      "source": "fontsource",
      "weights": [
        500,
        600,
        700
      ]
    },
    {
      "family": "Inter",
      "role": "body",
      "source": "fontsource",
      "weights": [
        400,
        500,
        600
      ]
    },
    {
      "family": "JetBrains Mono",
      "role": "mono",
      "source": "fontsource",
      "weights": [
        400,
        500
      ]
    }
  ],
  "tokens": {
    "light": {
      "color-surface": "oklch(98% 0.012 300)",
      "color-surface-raised": "oklch(99.5% 0.012 300)",
      "color-surface-overlay": "oklch(94.5% 0.016 300)",
      "color-surface-sunken": "oklch(96.2% 0.012 300)",
      "color-text-primary": "oklch(28% 0.03 295)",
      "color-text-muted": "oklch(52% 0.027 295)",
      "color-text-inverse": "oklch(99% 0.01 300)",
      "color-border": "oklch(86% 0.016 300)",
      "color-border-strong": "oklch(75% 0.02 300)",
      "color-focus-ring": "oklch(58% 0.2 295)",
      "color-accent": "oklch(58% 0.2 295)",
      "color-accent-hover": "oklch(52% 0.2 295)",
      "color-accent-weak": "color-mix(in oklch, var(--color-accent) 12%, var(--color-surface-raised))",
      "color-on-accent": "oklch(99% 0.01 300)",
      "color-brand-violet": "oklch(72% 0.15 350)",
      "color-danger": "oklch(52% 0.2 25)",
      "color-danger-hover": "oklch(46% 0.2 25)",
      "color-ok": "oklch(55% 0.13 150)",
      "color-warn": "oklch(70% 0.15 75)",
      "color-info": "oklch(55% 0.13 250)",
      "shadow-sm": "0 1px 2px oklch(40% 0.04 290 / 0.08)",
      "shadow-md": "0 6px 20px oklch(40% 0.04 290 / 0.1), 0 2px 6px oklch(40% 0.04 290 / 0.08)",
      "shadow-lg": "0 24px 54px oklch(38% 0.05 290 / 0.16)",
      "shadow-focus": "0 0 0 3px color-mix(in oklch, var(--color-focus-ring) 30%, transparent)",
      "color-scheme": "light"
    },
    "dark": {
      "color-surface": "oklch(20% 0.04 285)",
      "color-surface-raised": "oklch(24% 0.04 285)",
      "color-surface-overlay": "oklch(29% 0.052 285)",
      "color-surface-sunken": "oklch(16.5% 0.04 285)",
      "color-text-primary": "oklch(94% 0.015 300)",
      "color-text-muted": "oklch(69% 0.013 300)",
      "color-text-inverse": "oklch(20% 0.04 285)",
      "color-border": "oklch(35% 0.044 285)",
      "color-border-strong": "oklch(48% 0.048 285)",
      "color-focus-ring": "oklch(74% 0.18 295)",
      "color-accent": "oklch(72% 0.18 295)",
      "color-accent-hover": "oklch(79% 0.18 295)",
      "color-accent-weak": "color-mix(in oklch, var(--color-accent) 16%, var(--color-surface-raised))",
      "color-on-accent": "oklch(18% 0.04 295)",
      "color-brand-violet": "oklch(80% 0.13 200)",
      "color-danger": "oklch(66% 0.18 25)",
      "color-danger-hover": "oklch(72% 0.18 25)",
      "color-ok": "oklch(72% 0.14 150)",
      "color-warn": "oklch(80% 0.14 80)",
      "color-info": "oklch(74% 0.12 250)",
      "shadow-sm": "0 1px 2px oklch(0% 0 0 / 0.4)",
      "shadow-md": "0 10px 28px oklch(0% 0 0 / 0.5), 0 2px 6px oklch(0% 0 0 / 0.4)",
      "shadow-lg": "0 28px 60px oklch(0% 0 0 / 0.62)",
      "shadow-focus": "0 0 0 3px color-mix(in oklch, var(--color-focus-ring) 30%, transparent)",
      "color-scheme": "dark"
    }
  },
  "flags": {
    "feedLayout": "magazine",
    "cardStyle": "shadowed",
    "media": "plain",
    "hero": "fullbleed",
    "sectionRule": "none",
    "eyebrow": "plain"
  },
  "knobs": {
    "accent": {
      "light": "oklch(58% 0.2 295)",
      "dark": "oklch(72% 0.18 295)"
    },
    "surface": {
      "light": "oklch(98% 0.012 300)",
      "dark": "oklch(20% 0.04 285)"
    },
    "fontDisplay": "Space Grotesk",
    "fontBody": "Inter",
    "fontMono": "JetBrains Mono",
    "baseFontSize": "1.0625rem",
    "typeScale": 1.22,
    "density": "comfortable",
    "radius": "round"
  }
}
