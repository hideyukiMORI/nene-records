{
  "$schema": "../public-theme.schema.json",
  "id": "luxe",
  "name": "Editorial Luxe",
  "version": "1.0.0",
  "author": "NeNe Records",
  "description": "Editorial luxury — high-fashion magazine. Near-black ink and gold on a warm off-white (dark-leaning), extreme whitespace and a high-contrast Didone (Playfair Display) for theatrical, refined headlines. components.css is the star: dramatic Didone display, gold hairlines, full-bleed duotone hero and caps labels. Light + dark, both AA.",
  "supportsModes": [
    "light",
    "dark"
  ],
  "fonts": [
    {
      "family": "Playfair Display",
      "role": "display",
      "source": "fontsource",
      "weights": [
        600,
        700,
        900
      ]
    },
    {
      "family": "Inter",
      "role": "body",
      "source": "fontsource",
      "weights": [
        400,
        500,
        600
      ]
    },
    {
      "family": "JetBrains Mono",
      "role": "mono",
      "source": "fontsource",
      "weights": [
        400,
        500
      ]
    }
  ],
  "tokens": {
    "light": {
      "color-surface": "oklch(97% 0.006 80)",
      "color-surface-raised": "oklch(99% 0.006 80)",
      "color-surface-overlay": "oklch(93.5% 0.008 80)",
      "color-surface-sunken": "oklch(95.2% 0.006 80)",
      "color-text-primary": "oklch(20% 0.01 70)",
      "color-text-muted": "oklch(44% 0.009 70)",
      "color-text-inverse": "oklch(99% 0.006 80)",
      "color-border": "oklch(85% 0.01 80)",
      "color-border-strong": "oklch(74% 0.014 80)",
      "color-focus-ring": "oklch(66% 0.13 85)",
      "color-accent": "oklch(66% 0.13 85)",
      "color-accent-hover": "oklch(60% 0.13 85)",
      "color-accent-weak": "color-mix(in oklch, var(--color-accent) 12%, var(--color-surface-raised))",
      "color-on-accent": "oklch(18% 0.03 70)",
      "color-brand-violet": "oklch(56% 0.24 300)",
      "color-danger": "oklch(52% 0.2 25)",
      "color-danger-hover": "oklch(46% 0.2 25)",
      "color-ok": "oklch(55% 0.13 150)",
      "color-warn": "oklch(70% 0.15 75)",
      "color-info": "oklch(55% 0.13 250)",
      "shadow-sm": "0 1px 2px oklch(40% 0.04 80 / 0.08)",
      "shadow-md": "0 6px 20px oklch(40% 0.04 80 / 0.1), 0 2px 6px oklch(40% 0.04 80 / 0.08)",
      "shadow-lg": "0 24px 54px oklch(38% 0.05 80 / 0.16)",
      "shadow-focus": "0 0 0 3px color-mix(in oklch, var(--color-focus-ring) 30%, transparent)",
      "color-scheme": "light"
    },
    "dark": {
      "color-surface": "oklch(14% 0.005 60)",
      "color-surface-raised": "oklch(18% 0.005 60)",
      "color-surface-overlay": "oklch(23% 0.007 60)",
      "color-surface-sunken": "oklch(10.5% 0.005 60)",
      "color-text-primary": "oklch(93% 0.01 80)",
      "color-text-muted": "oklch(68% 0.009 80)",
      "color-text-inverse": "oklch(20% 0.005 60)",
      "color-border": "oklch(29% 0.009 60)",
      "color-border-strong": "oklch(42% 0.013 60)",
      "color-focus-ring": "oklch(80% 0.13 85)",
      "color-accent": "oklch(78% 0.13 85)",
      "color-accent-hover": "oklch(85% 0.13 85)",
      "color-accent-weak": "color-mix(in oklch, var(--color-accent) 16%, var(--color-surface-raised))",
      "color-on-accent": "oklch(15% 0.03 70)",
      "color-brand-violet": "oklch(72% 0.18 300)",
      "color-danger": "oklch(66% 0.18 25)",
      "color-danger-hover": "oklch(72% 0.18 25)",
      "color-ok": "oklch(72% 0.14 150)",
      "color-warn": "oklch(80% 0.14 80)",
      "color-info": "oklch(74% 0.12 250)",
      "shadow-sm": "0 1px 2px oklch(0% 0 0 / 0.4)",
      "shadow-md": "0 10px 28px oklch(0% 0 0 / 0.5), 0 2px 6px oklch(0% 0 0 / 0.4)",
      "shadow-lg": "0 28px 60px oklch(0% 0 0 / 0.62)",
      "shadow-focus": "0 0 0 3px color-mix(in oklch, var(--color-focus-ring) 30%, transparent)",
      "color-scheme": "dark"
    }
  },
  "flags": {
    "feedLayout": "magazine",
    "cardStyle": "flat",
    "media": "duotone",
    "hero": "fullbleed",
    "sectionRule": "hairline",
    "eyebrow": "caps"
  },
  "knobs": {
    "accent": {
      "light": "oklch(66% 0.13 85)",
      "dark": "oklch(78% 0.13 85)"
    },
    "surface": {
      "light": "oklch(97% 0.006 80)",
      "dark": "oklch(14% 0.005 60)"
    },
    "fontDisplay": "Playfair Display",
    "fontBody": "Inter",
    "fontMono": "JetBrains Mono",
    "baseFontSize": "1.0625rem",
    "typeScale": 1.33,
    "density": "comfortable",
    "radius": "sharp"
  }
}
