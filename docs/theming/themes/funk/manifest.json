{
  "$schema": "../public-theme.schema.json",
  "id": "funk",
  "name": "Funk",
  "version": "1.0.0",
  "author": "NeNe Records",
  "description": "Retro 70s funk — mustard, rust and avocado warmth, round chunky display type (Fredoka) and a groovy, easygoing rhythm. Playful but mellow. components.css is the star: fat rounded headlines, big rounded cards, duotone media, heavy rules and barred retro eyebrows. Light + dark, both AA.",
  "supportsModes": [
    "light",
    "dark"
  ],
  "fonts": [
    {
      "family": "Fredoka",
      "role": "display",
      "source": "fontsource",
      "weights": [
        500,
        600,
        700
      ]
    },
    {
      "family": "Inter",
      "role": "body",
      "source": "fontsource",
      "weights": [
        400,
        500,
        600
      ]
    },
    {
      "family": "JetBrains Mono",
      "role": "mono",
      "source": "fontsource",
      "weights": [
        400,
        500
      ]
    }
  ],
  "tokens": {
    "light": {
      "color-surface": "oklch(95% 0.03 85)",
      "color-surface-raised": "oklch(97% 0.03 85)",
      "color-surface-overlay": "oklch(91.5% 0.039 85)",
      "color-surface-sunken": "oklch(93.2% 0.03 85)",
      "color-text-primary": "oklch(26% 0.03 60)",
      "color-text-muted": "oklch(50% 0.027 60)",
      "color-text-inverse": "oklch(99% 0.01 85)",
      "color-border": "oklch(83% 0.034 85)",
      "color-border-strong": "oklch(72% 0.038 85)",
      "color-focus-ring": "oklch(62% 0.15 55)",
      "color-accent": "oklch(62% 0.15 55)",
      "color-accent-hover": "oklch(56% 0.15 55)",
      "color-accent-weak": "color-mix(in oklch, var(--color-accent) 12%, var(--color-surface-raised))",
      "color-on-accent": "oklch(20% 0.05 55)",
      "color-brand-violet": "oklch(58% 0.12 135)",
      "color-danger": "oklch(52% 0.2 25)",
      "color-danger-hover": "oklch(46% 0.2 25)",
      "color-ok": "oklch(55% 0.13 150)",
      "color-warn": "oklch(70% 0.15 75)",
      "color-info": "oklch(55% 0.13 250)",
      "shadow-sm": "0 1px 2px oklch(40% 0.04 55 / 0.08)",
      "shadow-md": "0 6px 20px oklch(40% 0.04 55 / 0.1), 0 2px 6px oklch(40% 0.04 55 / 0.08)",
      "shadow-lg": "0 24px 54px oklch(38% 0.05 55 / 0.16)",
      "shadow-focus": "0 0 0 3px color-mix(in oklch, var(--color-focus-ring) 30%, transparent)",
      "color-scheme": "light"
    },
    "dark": {
      "color-surface": "oklch(22% 0.03 60)",
      "color-surface-raised": "oklch(26% 0.03 60)",
      "color-surface-overlay": "oklch(31% 0.039 60)",
      "color-surface-sunken": "oklch(18.5% 0.03 60)",
      "color-text-primary": "oklch(93% 0.02 80)",
      "color-text-muted": "oklch(68% 0.018 80)",
      "color-text-inverse": "oklch(20% 0.03 60)",
      "color-border": "oklch(37% 0.034 60)",
      "color-border-strong": "oklch(50% 0.038 60)",
      "color-focus-ring": "oklch(74% 0.15 55)",
      "color-accent": "oklch(72% 0.15 55)",
      "color-accent-hover": "oklch(79% 0.15 55)",
      "color-accent-weak": "color-mix(in oklch, var(--color-accent) 16%, var(--color-surface-raised))",
      "color-on-accent": "oklch(20% 0.05 55)",
      "color-brand-violet": "oklch(70% 0.12 135)",
      "color-danger": "oklch(66% 0.18 25)",
      "color-danger-hover": "oklch(72% 0.18 25)",
      "color-ok": "oklch(72% 0.14 150)",
      "color-warn": "oklch(80% 0.14 80)",
      "color-info": "oklch(74% 0.12 250)",
      "shadow-sm": "0 1px 2px oklch(0% 0 0 / 0.4)",
      "shadow-md": "0 10px 28px oklch(0% 0 0 / 0.5), 0 2px 6px oklch(0% 0 0 / 0.4)",
      "shadow-lg": "0 28px 60px oklch(0% 0 0 / 0.62)",
      "shadow-focus": "0 0 0 3px color-mix(in oklch, var(--color-focus-ring) 30%, transparent)",
      "color-scheme": "dark"
    }
  },
  "flags": {
    "feedLayout": "magazine",
    "cardStyle": "shadowed",
    "media": "duotone",
    "hero": "standard",
    "sectionRule": "heavy",
    "eyebrow": "barred"
  },
  "knobs": {
    "accent": {
      "light": "oklch(62% 0.15 55)",
      "dark": "oklch(72% 0.15 55)"
    },
    "surface": {
      "light": "oklch(95% 0.03 85)",
      "dark": "oklch(22% 0.03 60)"
    },
    "fontDisplay": "Fredoka",
    "fontBody": "Inter",
    "fontMono": "JetBrains Mono",
    "baseFontSize": "1.0625rem",
    "typeScale": 1.2,
    "density": "comfortable",
    "radius": "round"
  }
}
