{
  "$schema": "../public-theme.schema.json",
  "id": "kraft",
  "name": "Kraft",
  "version": "1.0.0",
  "author": "NeNe Records",
  "description": "Recycled kraft paper — a tactile cardboard-tan ground, a hand-stamped ink-red accent, condensed poster type and an eco, handmade feel. components.css is the star: stamped badges, taped/rough edges, condensed Oswald headers and a warm utilitarian rhythm. Light + dark, both AA.",
  "supportsModes": [
    "light",
    "dark"
  ],
  "fonts": [
    {
      "family": "Oswald",
      "role": "display",
      "source": "fontsource",
      "weights": [
        500,
        600,
        700
      ]
    },
    {
      "family": "Inter",
      "role": "body",
      "source": "fontsource",
      "weights": [
        400,
        500,
        600
      ]
    },
    {
      "family": "JetBrains Mono",
      "role": "mono",
      "source": "fontsource",
      "weights": [
        400,
        500
      ]
    }
  ],
  "tokens": {
    "light": {
      "color-surface": "oklch(90% 0.035 80)",
      "color-surface-raised": "oklch(92% 0.035 80)",
      "color-surface-overlay": "oklch(86.5% 0.046 80)",
      "color-surface-sunken": "oklch(88.2% 0.035 80)",
      "color-text-primary": "oklch(27% 0.03 60)",
      "color-text-muted": "oklch(51% 0.027 60)",
      "color-text-inverse": "oklch(99% 0.01 80)",
      "color-border": "oklch(78% 0.039 80)",
      "color-border-strong": "oklch(67% 0.043 80)",
      "color-focus-ring": "oklch(48% 0.16 30)",
      "color-accent": "oklch(48% 0.16 30)",
      "color-accent-hover": "oklch(42% 0.16 30)",
      "color-accent-weak": "color-mix(in oklch, var(--color-accent) 12%, var(--color-surface-raised))",
      "color-on-accent": "oklch(98% 0.01 80)",
      "color-brand-violet": "oklch(45% 0.1 150)",
      "color-danger": "oklch(52% 0.2 25)",
      "color-danger-hover": "oklch(46% 0.2 25)",
      "color-ok": "oklch(55% 0.13 150)",
      "color-warn": "oklch(70% 0.15 75)",
      "color-info": "oklch(55% 0.13 250)",
      "shadow-sm": "0 1px 2px oklch(40% 0.04 70 / 0.08)",
      "shadow-md": "0 6px 20px oklch(40% 0.04 70 / 0.1), 0 2px 6px oklch(40% 0.04 70 / 0.08)",
      "shadow-lg": "0 24px 54px oklch(38% 0.05 70 / 0.16)",
      "shadow-focus": "0 0 0 3px color-mix(in oklch, var(--color-focus-ring) 30%, transparent)",
      "color-scheme": "light"
    },
    "dark": {
      "color-surface": "oklch(24% 0.026 60)",
      "color-surface-raised": "oklch(28% 0.026 60)",
      "color-surface-overlay": "oklch(33% 0.034 60)",
      "color-surface-sunken": "oklch(20.5% 0.026 60)",
      "color-text-primary": "oklch(91% 0.03 75)",
      "color-text-muted": "oklch(66% 0.027 75)",
      "color-text-inverse": "oklch(20% 0.026 60)",
      "color-border": "oklch(39% 0.03 60)",
      "color-border-strong": "oklch(52% 0.034 60)",
      "color-focus-ring": "oklch(62% 0.17 30)",
      "color-accent": "oklch(60% 0.17 30)",
      "color-accent-hover": "oklch(67% 0.17 30)",
      "color-accent-weak": "color-mix(in oklch, var(--color-accent) 16%, var(--color-surface-raised))",
      "color-on-accent": "oklch(16% 0.03 30)",
      "color-brand-violet": "oklch(68% 0.1 150)",
      "color-danger": "oklch(66% 0.18 25)",
      "color-danger-hover": "oklch(72% 0.18 25)",
      "color-ok": "oklch(72% 0.14 150)",
      "color-warn": "oklch(80% 0.14 80)",
      "color-info": "oklch(74% 0.12 250)",
      "shadow-sm": "0 1px 2px oklch(0% 0 0 / 0.4)",
      "shadow-md": "0 10px 28px oklch(0% 0 0 / 0.5), 0 2px 6px oklch(0% 0 0 / 0.4)",
      "shadow-lg": "0 28px 60px oklch(0% 0 0 / 0.62)",
      "shadow-focus": "0 0 0 3px color-mix(in oklch, var(--color-focus-ring) 30%, transparent)",
      "color-scheme": "dark"
    }
  },
  "flags": {
    "feedLayout": "magazine",
    "cardStyle": "bordered",
    "media": "duotone",
    "hero": "standard",
    "sectionRule": "heavy",
    "eyebrow": "caps"
  },
  "knobs": {
    "accent": {
      "light": "oklch(48% 0.16 30)",
      "dark": "oklch(60% 0.17 30)"
    },
    "surface": {
      "light": "oklch(90% 0.035 80)",
      "dark": "oklch(24% 0.026 60)"
    },
    "fontDisplay": "Oswald",
    "fontBody": "Inter",
    "fontMono": "JetBrains Mono",
    "baseFontSize": "1.0625rem",
    "typeScale": 1.2,
    "density": "comfortable",
    "radius": "soft"
  }
}
