{
  "$schema": "../public-theme.schema.json",
  "id": "sumi",
  "name": "Sumi-e",
  "version": "1.0.0",
  "author": "NeNe Records",
  "description": "Japanese ink wash (sumi-e) — warm washi paper, sumi-black ink and a single vermilion seal, a mincho serif (Shippori Mincho) and grayscale brush imagery. Calm, traditional, vertical. components.css is the star: mincho headings, a vermilion seal eyebrow, hairline rules, grayscale media and generous washi margins. Light + dark, both AA.",
  "supportsModes": [
    "light",
    "dark"
  ],
  "fonts": [
    {
      "family": "Shippori Mincho",
      "role": "display",
      "source": "fontsource",
      "weights": [
        500,
        600,
        700
      ]
    },
    {
      "family": "Shippori Mincho",
      "role": "body",
      "source": "fontsource",
      "weights": [
        400,
        500
      ]
    },
    {
      "family": "JetBrains Mono",
      "role": "mono",
      "source": "fontsource",
      "weights": [
        400,
        500
      ]
    }
  ],
  "tokens": {
    "light": {
      "color-surface": "oklch(95% 0.014 85)",
      "color-surface-raised": "oklch(97% 0.014 85)",
      "color-surface-overlay": "oklch(91.5% 0.018 85)",
      "color-surface-sunken": "oklch(93.2% 0.014 85)",
      "color-text-primary": "oklch(20% 0.01 60)",
      "color-text-muted": "oklch(44% 0.009 60)",
      "color-text-inverse": "oklch(99% 0.01 85)",
      "color-border": "oklch(83% 0.018 85)",
      "color-border-strong": "oklch(72% 0.022 85)",
      "color-focus-ring": "oklch(55% 0.18 30)",
      "color-accent": "oklch(55% 0.18 30)",
      "color-accent-hover": "oklch(49% 0.18 30)",
      "color-accent-weak": "color-mix(in oklch, var(--color-accent) 12%, var(--color-surface-raised))",
      "color-on-accent": "oklch(99% 0.01 85)",
      "color-brand-violet": "oklch(50% 0.1 300)",
      "color-danger": "oklch(52% 0.2 25)",
      "color-danger-hover": "oklch(46% 0.2 25)",
      "color-ok": "oklch(55% 0.13 150)",
      "color-warn": "oklch(70% 0.15 75)",
      "color-info": "oklch(55% 0.13 250)",
      "shadow-sm": "0 1px 2px oklch(40% 0.04 60 / 0.08)",
      "shadow-md": "0 6px 20px oklch(40% 0.04 60 / 0.1), 0 2px 6px oklch(40% 0.04 60 / 0.08)",
      "shadow-lg": "0 24px 54px oklch(38% 0.05 60 / 0.16)",
      "shadow-focus": "0 0 0 3px color-mix(in oklch, var(--color-focus-ring) 30%, transparent)",
      "color-scheme": "light"
    },
    "dark": {
      "color-surface": "oklch(16% 0.006 60)",
      "color-surface-raised": "oklch(20% 0.006 60)",
      "color-surface-overlay": "oklch(25% 0.008 60)",
      "color-surface-sunken": "oklch(12.5% 0.006 60)",
      "color-text-primary": "oklch(92% 0.01 80)",
      "color-text-muted": "oklch(67% 0.009 80)",
      "color-text-inverse": "oklch(20% 0.006 60)",
      "color-border": "oklch(31% 0.01 60)",
      "color-border-strong": "oklch(44% 0.014 60)",
      "color-focus-ring": "oklch(64% 0.18 30)",
      "color-accent": "oklch(62% 0.18 30)",
      "color-accent-hover": "oklch(69% 0.18 30)",
      "color-accent-weak": "color-mix(in oklch, var(--color-accent) 16%, var(--color-surface-raised))",
      "color-on-accent": "oklch(15% 0.03 30)",
      "color-brand-violet": "oklch(70% 0.1 300)",
      "color-danger": "oklch(66% 0.18 25)",
      "color-danger-hover": "oklch(72% 0.18 25)",
      "color-ok": "oklch(72% 0.14 150)",
      "color-warn": "oklch(80% 0.14 80)",
      "color-info": "oklch(74% 0.12 250)",
      "shadow-sm": "0 1px 2px oklch(0% 0 0 / 0.4)",
      "shadow-md": "0 10px 28px oklch(0% 0 0 / 0.5), 0 2px 6px oklch(0% 0 0 / 0.4)",
      "shadow-lg": "0 28px 60px oklch(0% 0 0 / 0.62)",
      "shadow-focus": "0 0 0 3px color-mix(in oklch, var(--color-focus-ring) 30%, transparent)",
      "color-scheme": "dark"
    }
  },
  "flags": {
    "feedLayout": "magazine",
    "cardStyle": "flat",
    "media": "grayscale",
    "hero": "minimal",
    "sectionRule": "hairline",
    "eyebrow": "caps"
  },
  "knobs": {
    "accent": {
      "light": "oklch(55% 0.18 30)",
      "dark": "oklch(62% 0.18 30)"
    },
    "surface": {
      "light": "oklch(95% 0.014 85)",
      "dark": "oklch(16% 0.006 60)"
    },
    "fontDisplay": "Shippori Mincho",
    "fontBody": "Shippori Mincho",
    "fontMono": "JetBrains Mono",
    "baseFontSize": "1.0625rem",
    "typeScale": 1.2,
    "density": "comfortable",
    "radius": "soft"
  }
}
