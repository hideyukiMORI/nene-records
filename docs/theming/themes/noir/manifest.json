{
  "$schema": "../public-theme.schema.json",
  "id": "noir",
  "name": "Noir",
  "version": "1.0.0",
  "author": "NeNe Records",
  "description": "Dark-first, high-contrast editorial — the 4th axis against consumer (warm soft), aurora (cool tech) and reading (serif). Inky, slightly-cool near-black paper carries an electric acid-lime accent and oversized Space Grotesk display type. components.css is the star: giant display, restrained neon glow, hard editorial rules, framed cards with a neon top edge, and neon-duotone media. Light is the inverted bright sister; both AA.",
  "supportsModes": ["light", "dark"],
  "fonts": [
    { "family": "Space Grotesk", "role": "display", "source": "fontsource", "weights": [400, 500, 700] },
    { "family": "Space Grotesk", "role": "chrome", "source": "fontsource", "weights": [500, 700] },
    { "family": "Inter", "role": "body", "source": "fontsource", "weights": [400, 500, 600] },
    { "family": "JetBrains Mono", "role": "mono", "source": "fontsource", "weights": [400, 500] }
  ],
  "tokens": {
    "light": {
      "color-surface": "oklch(97% 0.004 280)",
      "color-surface-raised": "oklch(99.5% 0.003 280)",
      "color-surface-overlay": "oklch(93% 0.008 280)",
      "color-surface-sunken": "oklch(93.5% 0.006 280)",
      "color-text-primary": "oklch(20% 0.01 280)",
      "color-text-muted": "oklch(46% 0.014 280)",
      "color-text-inverse": "oklch(99% 0.003 280)",
      "color-border": "oklch(86% 0.008 280)",
      "color-border-strong": "oklch(72% 0.014 280)",
      "color-focus-ring": "oklch(58% 0.15 128)",
      "color-accent": "oklch(54% 0.15 128)",
      "color-accent-hover": "oklch(48% 0.15 128)",
      "color-accent-weak": "color-mix(in oklch, var(--color-accent) 12%, var(--color-surface-raised))",
      "color-on-accent": "oklch(17% 0.03 128)",
      "color-brand-violet": "oklch(52% 0.22 300)",
      "color-danger": "oklch(52% 0.2 25)",
      "color-danger-hover": "oklch(46% 0.2 25)",
      "color-ok": "oklch(52% 0.13 150)",
      "color-warn": "oklch(68% 0.15 75)",
      "color-info": "oklch(52% 0.13 250)",
      "shadow-sm": "0 1px 2px oklch(30% 0.02 280 / 0.08)",
      "shadow-md": "0 2px 4px oklch(30% 0.02 280 / 0.08), 0 12px 28px oklch(30% 0.02 280 / 0.08)",
      "shadow-lg": "0 20px 48px oklch(30% 0.03 280 / 0.14)",
      "shadow-focus": "0 0 0 3px color-mix(in oklch, var(--color-focus-ring) 30%, transparent)",
      "color-scheme": "light"
    },
    "dark": {
      "color-surface": "oklch(15% 0.012 280)",
      "color-surface-raised": "oklch(19% 0.014 280)",
      "color-surface-overlay": "oklch(24% 0.016 280)",
      "color-surface-sunken": "oklch(10.5% 0.01 280)",
      "color-text-primary": "oklch(96% 0.004 280)",
      "color-text-muted": "oklch(70% 0.012 280)",
      "color-text-inverse": "oklch(15% 0.012 280)",
      "color-border": "oklch(30% 0.014 280)",
      "color-border-strong": "oklch(46% 0.02 280)",
      "color-focus-ring": "oklch(86% 0.21 128)",
      "color-accent": "oklch(86% 0.21 128)",
      "color-accent-hover": "oklch(92% 0.18 128)",
      "color-accent-weak": "color-mix(in oklch, var(--color-accent) 16%, var(--color-surface-raised))",
      "color-on-accent": "oklch(18% 0.03 128)",
      "color-brand-violet": "oklch(72% 0.18 300)",
      "color-danger": "oklch(66% 0.18 25)",
      "color-danger-hover": "oklch(72% 0.18 25)",
      "color-ok": "oklch(72% 0.14 150)",
      "color-warn": "oklch(80% 0.14 80)",
      "color-info": "oklch(74% 0.12 250)",
      "shadow-sm": "0 1px 0 oklch(0% 0 0 / 0.5)",
      "shadow-md": "0 2px 0 oklch(0% 0 0 / 0.45), 0 14px 30px oklch(0% 0 0 / 0.5)",
      "shadow-lg": "0 24px 60px oklch(0% 0 0 / 0.62)",
      "shadow-focus": "0 0 0 3px color-mix(in oklch, var(--color-focus-ring) 36%, transparent)",
      "color-scheme": "dark"
    }
  },
  "flags": {
    "feedLayout": "magazine",
    "cardStyle": "framed",
    "media": "duotone",
    "hero": "fullbleed",
    "sectionRule": "heavy",
    "eyebrow": "caps"
  },
  "knobs": {
    "accent": { "light": "oklch(54% 0.15 128)", "dark": "oklch(86% 0.21 128)" },
    "surface": { "light": "oklch(97% 0.004 280)", "dark": "oklch(15% 0.012 280)" },
    "textPrimary": { "light": "oklch(20% 0.01 280)", "dark": "oklch(96% 0.004 280)" },
    "fontDisplay": "Space Grotesk",
    "fontBody": "Inter",
    "fontMono": "JetBrains Mono",
    "baseFontSize": "1.0625rem",
    "typeScale": 1.3,
    "density": "comfortable",
    "radius": "sharp"
  }
}
