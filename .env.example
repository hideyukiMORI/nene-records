APP_ENV=local
APP_DEBUG=false
APP_NAME=NeNe Records
NENE2_MACHINE_API_KEY=
NENE2_LOCAL_JWT_SECRET=
PROBLEM_DETAILS_BASE_URL=https://nene-records.dev/problems/

# --- Database (host / PHPUnit default: SQLite) ---
DATABASE_URL=
DB_ENV=local
DB_ADAPTER=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=var/nene_records.sqlite
DB_USER=nene_records
DB_PASSWORD=
DB_CHARSET=utf8mb4

# --- Docker Compose overrides (copy to .env and uncomment for local stack) ---
# DB_ADAPTER=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_NAME=nene_records
# DB_USER=nene_records
# DB_PASSWORD=nene_records
# MYSQL_ROOT_PASSWORD=nene_records_root
#
# Ports — 180xx/133xx に固定（NeNeClear=83xx、汎用ツール=80xx と競合しないよう隔離）
# NENE_RECORDS_PORT=18082
# NENE_RECORDS_MYSQL_PORT=13308
# NENE_RECORDS_PHPMYADMIN_PORT=18083
# NENE_RECORDS_MAILPIT_WEB_PORT=18026
# NENE_RECORDS_FRONTEND_PORT=18084
#
# --- Mail (Docker Mailpit; production uses your host SMTP relay) ---
# MAIL_DSN=smtp://mailpit:1025
# MAIL_FROM=noreply@nene-records.local
