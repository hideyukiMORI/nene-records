# NeNe Records MCP bridge — copy to .env and fill in. .env is gitignored.
# Loaded automatically by `npm start` (node --env-file-if-exists=.env).

# NeNe Records API base URL (the bridge proxies tool calls here).
NENE_API_BASE=http://localhost:18082

# Auth — prefer email/password so the bridge refreshes its own JWT.
# Admin tokens expire after 24h, so a static NENE_API_TOKEN dies overnight for
# an always-on bridge. With credentials the bridge re-logs in on a 401.
NENE_API_EMAIL=admin@nene-records.local
NENE_API_PASSWORD=change-me
# NENE_API_TOKEN=        # one-shot fallback instead of email/password

# Tool exposure.
MCP_TOOLS=themes         # themes | all
MCP_READONLY=1           # 1 = read tools only; 0 = enable create/update/delete

# Shared-secret guard. REQUIRED when MCP_READONLY=0 (the bridge refuses to start
# otherwise). Append it to the connector URL as ?key=<secret>.
# Generate one: openssl rand -hex 32
MCP_BRIDGE_SECRET=

# Network.
MCP_PORT=8765
MCP_PATH=/mcp
